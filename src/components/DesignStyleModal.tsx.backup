            }
        ],
        typography: {
            primary: 'Orbitron, system-ui, sans-serif',
            secondary: 'Inter, system-ui, sans-serif',
            weights: ['400', '500', '600', '700', '900']
        },
        spacing: ['4px', '8px', '16px', '24px', '32px', '48px'],
        borderRadius: ['4px', '8px', '16px']
    }
];

interface DesignStyleModalProps {
    isOpen: boolean;
    onClose: () => void;
    onStyleSelect: (style: DesignStyle) => void;
    selectedStyleId?: string;
    projectType: string;
    hasUploadedProject?: boolean;
    onApplyToProject?: () => void;
}

const DesignStyleModal: React.FC<DesignStyleModalProps> = ({
    isOpen,
    onClose,
    onStyleSelect,
    selectedStyleId,
    projectType,
    hasUploadedProject = false,
    onApplyToProject
}) => {
    const [selectedCategory, setSelectedCategory] = useState<string>('all');
    const [expandedStyle, setExpandedStyle] = useState<string | null>(null);

    // Close modal on escape key
    useEffect(() => {
        const handleEscape = (e: KeyboardEvent) => {
            if (e.key === 'Escape') onClose();
        };

        if (isOpen) {
            document.addEventListener('keydown', handleEscape);
            document.body.style.overflow = 'hidden';
        }

        return () => {
            document.removeEventListener('keydown', handleEscape);
            document.body.style.overflow = 'unset';
        };
    }, [isOpen, onClose]);

    if (!isOpen) return null;

    const categories = ['all', ...Array.from(new Set(designStyles.map(style => style.category)))];
    const filteredStyles = selectedCategory === 'all'
        ? designStyles
        : designStyles.filter(style => style.category === selectedCategory);

    // Filter styles by project type compatibility
    const compatibleStyles = filteredStyles.filter(style =>
        style.projectTypes.includes(projectType)
    );

    const handleStyleSelect = (style: DesignStyle) => {
        onStyleSelect(style);
        setExpandedStyle(expandedStyle === style.id ? null : style.id);
    };

    const handleApplyAndClose = () => {
        if (onApplyToProject) {
            onApplyToProject();
        }
        onClose();
    };

    return (
        <Dialog
            open={isOpen}
            onClose={onClose}
            maxWidth="xl"
            fullWidth
            sx={{
                '& .MuiDialog-paper': {
                    maxHeight: '90vh',
                    borderRadius: 3,
                }
            }}
        >
            <DialogTitle sx={{ pb: 0 }}>
                <Box sx={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                    <Box sx={{ display: 'flex', alignItems: 'center', gap: 2 }}>
                        <Avatar sx={{ bgcolor: 'primary.light' }}>
                            <PaletteIcon />
                        </Avatar>
                        <Box>
                            <Typography variant="h5" component="h2">
                                Design Style Library
                            </Typography>
                            <Typography variant="body2" color="text.secondary">
                                Choose a design style for your {projectType} project
                            </Typography>
                        </Box>
                    </Box>
                    <Box sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
                        {hasUploadedProject && selectedStyleId && (
                            <Button
                                onClick={handleApplyAndClose}
                                variant="contained"
                                startIcon={<FlashIcon />}
                            >
                                Apply & Close
                            </Button>
                        )}
                        <IconButton onClick={onClose} aria-label="Close modal">
                            <CloseIcon />
                        </IconButton>
                    </Box>
                </Box>
            </DialogTitle>

            <Box sx={{ px: 3, py: 1, bgcolor: 'info.light', borderBottom: 1, borderColor: 'info.main' }}>
                <Box sx={{ display: 'flex', alignItems: 'center', gap: 1.5 }}>
                    <InfoIcon color="info" />
                    <Box>
                        <Typography variant="body2" fontWeight="medium" sx={{ color: 'info.contrastText' }}>
                            Showing styles optimized for <Box component="span" sx={{ textTransform: 'capitalize', fontWeight: 'bold' }}>{projectType}</Box> projects
                        </Typography>
                        <Typography variant="caption" color="info.main">
                            {compatibleStyles.length} compatible styles available • All styles are WCAG compliant
                        </Typography>
                    </Box>
                </Box>
            </Box>

            <Box sx={{ px: 3, py: 2, borderBottom: 1, borderColor: 'divider' }}>
                <Stack direction="row" spacing={1} sx={{ flexWrap: 'wrap' }}>
                    {categories.map(category => (
                        <Chip
                            key={category}
                            label={`${category === 'all' ? 'All Categories' : category} (${category === 'all' ? compatibleStyles.length : compatibleStyles.filter(s => s.category === category).length})`}
                            onClick={() => setSelectedCategory(category)}
                            variant={selectedCategory === category ? 'filled' : 'outlined'}
                            color={selectedCategory === category ? 'primary' : 'default'}
                            size="small"
                        />
                    ))}
                </Stack>
            </Box>

            <DialogContent sx={{ p: 3 }}>
                <Box sx={{ display: 'grid', gridTemplateColumns: { xs: '1fr', lg: 'repeat(2, 1fr)' }, gap: 3 }}>
                    {compatibleStyles.map((style) => (
                        <Card
                            key={style.id}
                            sx={{
                                border: selectedStyleId === style.id ? 2 : 1,
                                borderColor: selectedStyleId === style.id ? 'primary.main' : 'divider',
                                    bgcolor: selectedStyleId === style.id ? 'primary.light' : 'background.paper',
                                    transition: 'all 0.2s ease-in-out',
                                    '&:hover': {
                                        boxShadow: 3,
                                    }
                                }}
                            >
                                <CardContent sx={{ p: 3 }}>
                                    <Box
                                        onClick={() => handleStyleSelect(style)}
                                        sx={{ cursor: 'pointer', '&:hover': { bgcolor: 'action.hover' }, p: 1, borderRadius: 1, mb: 2 }}
                                    >
                                        <Box sx={{ display: 'flex', alignItems: 'flex-start', justifyContent: 'space-between', mb: 2 }}>
                                            <Box sx={{ display: 'flex', alignItems: 'center', gap: 2 }}>
                                                <Avatar sx={{
                                                    bgcolor: selectedStyleId === style.id ? 'primary.main' : 'grey.200',
                                                    color: selectedStyleId === style.id ? 'primary.contrastText' : 'text.primary'
                                                }}>
                                                    {style.icon}
                                                </Avatar>
                                                <Box>
                                                    <Box sx={{ display: 'flex', alignItems: 'center', gap: 1, mb: 1 }}>
                                                        <Typography variant="h6">
                                                            {style.name}
                                                        </Typography>
                                                        {selectedStyleId === style.id && <CheckIcon color="primary" />}
                                                        {style.wcagCompliant && (
                                                            <Chip label="WCAG AA" size="small" color="success" variant="outlined" />
                                                        )}
                                                    </Box>
                                                    <Typography variant="body2" color="text.secondary" sx={{ mb: 1 }}>
                                                        {style.description}
                                                    </Typography>
                                                    <Box sx={{ display: 'flex', gap: 1 }}>
                                                        <Chip label={style.category} size="small" variant="outlined" />
                                                        <Chip label={`${style.popularity}/10 Popular`} size="small" variant="outlined" />
                                                    </Box>
                                                </Box>
                                            </Box>
                                            <ChevronRightIcon
                                                sx={{
                                                    transform: expandedStyle === style.id ? 'rotate(90deg)' : 'rotate(0deg)',
                                                    transition: 'transform 0.2s',
                                                    color: 'action.disabled'
                                                }}
                                            />
                                        </Box>

                                        <Box sx={{ mb: 2 }}>
                                            <Typography variant="subtitle2" sx={{ mb: 1 }}>Color Palette</Typography>
                                            <Box sx={{ display: 'flex', gap: 0.5 }}>
                                                {style.colorSchemes[0].colors.slice(0, 8).map((color, index) => (
                                                    <Box
                                                        key={index}
                                                        sx={{
                                                            width: 32,
                                                            height: 32,
                                                            bgcolor: color,
                                                            border: 1,
                                                            borderColor: 'divider',
                                                            borderRadius: 0.5,
                                                        }}
                                                        title={color}
                                                    />
                                                ))}
                                            </Box>
                                        </Box>

                                        <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 1 }}>
                                            {style.characteristics.slice(0, 4).map((char, index) => (
                                                <Chip key={index} label={char} size="small" color="primary" variant="outlined" />
                                            ))}
                                            {style.characteristics.length > 4 && (
                                                <Typography variant="caption" color="text.secondary">
                                                    +{style.characteristics.length - 4} more
                                                </Typography>
                                            )}
                                        </Box>
                                    </Box>

                                    <Collapse in={expandedStyle === style.id}>
                                        <Divider sx={{ my: 2 }} />
                                        <Box sx={{ display: 'grid', gridTemplateColumns: { xs: '1fr', md: 'repeat(2, 1fr)' }, gap: 3 }}>
                                            <Box>
                                                <Typography variant="subtitle2" sx={{ mb: 2 }}>Typography</Typography>
                                                <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1 }}>
                                                    <Box>
                                                        <Typography variant="caption" color="text.secondary">Primary:</Typography>
                                                        <Typography variant="body2" component="code" sx={{ ml: 1, bgcolor: 'background.default', px: 1, py: 0.5, borderRadius: 0.5, fontFamily: 'monospace' }}>
                                                            {style.typography.primary}
                                                        </Typography>
                                                    </Box>
                                                    <Box>
                                                        <Typography variant="caption" color="text.secondary">Weights:</Typography>
                                                        <Box sx={{ display: 'flex', gap: 0.5, mt: 0.5, flexWrap: 'wrap' }}>
                                                            {style.typography.weights.map((weight, index) => (
                                                                <Chip key={index} label={weight} size="small" variant="outlined" />
                                                            ))}
                                                        </Box>
                                                    </Box>
                                                </Box>
                                            </Box>

                                            <Box>
                                                <Typography variant="subtitle2" sx={{ mb: 2 }}>Spacing & Radius</Typography>
                                                <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1 }}>
                                                    <Box>
                                                        <Typography variant="caption" color="text.secondary">Spacing Scale:</Typography>
                                                        <Box sx={{ display: 'flex', gap: 0.5, mt: 0.5, flexWrap: 'wrap' }}>
                                                            {style.spacing.slice(0, 6).map((space, index) => (
                                                                <Chip key={index} label={space} size="small" variant="outlined" />
                                                            ))}
                                                        </Box>
                                                    </Box>
                                                    <Box>
                                                        <Typography variant="caption" color="text.secondary">Border Radius:</Typography>
                                                        <Box sx={{ display: 'flex', gap: 0.5, mt: 0.5 }}>
                                                            {style.borderRadius.map((radius, index) => (
                                                                <Chip key={index} label={radius} size="small" variant="outlined" />
                                                            ))}
                                                        </Box>
                                                    </Box>
                                                </Box>
                                            </Box>

                                        </Box>

                                        <Box sx={{ mt: 3 }}>
                                            <Typography variant="subtitle2" sx={{ mb: 2 }}>All Characteristics</Typography>
                                            <Box sx={{ display: 'flex', flexWrap: 'wrap', gap: 1 }}>
                                                {style.characteristics.map((char, index) => (
                                                    <Chip key={index} label={char} size="small" color="primary" />
                                                ))}
                                            </Box>
                                        </Box>
                                    </Collapse>
                                </CardContent>
                            </Card>
                        </Box>
                    ))}
                </Box>

                {compatibleStyles.length === 0 && (
                    <Box sx={{ textAlign: 'center', py: 6 }}>
                        <Avatar sx={{ bgcolor: 'grey.200', width: 64, height: 64, mx: 'auto', mb: 2 }}>
                            <PaletteIcon sx={{ color: 'text.disabled' }} />
                        </Avatar>
                        <Typography variant="h6" color="text.secondary" sx={{ mb: 1 }}>
                            No compatible styles found
                        </Typography>
                        <Typography variant="body2" color="text.disabled">
                            Try selecting a different category or project type
                        </Typography>
                    </Box>
                )}
            </DialogContent>
        </Dialog>
    );
};

export default DesignStyleModal;