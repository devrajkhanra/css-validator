        icon: <PaletteIcon sx={{ width: 20, height: 20 }} />,
        category: 'Creative',
        popularity: 7,
        projectTypes: ['portfolio', 'landing', 'app'],
        wcagCompliant: true,
        characteristics: ['Bold colors', 'Expressive', 'Creative freedom', 'Visual impact', 'Artistic'],
        colorSchemes: [
            {
                name: 'Creative Purple',
                colors: ['#ffffff', '#faf5ff', '#a855f7', '#9333ea', '#7c3aed', '#6d28d9', '#581c87', '#000000'],
