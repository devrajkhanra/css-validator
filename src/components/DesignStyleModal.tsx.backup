                colors: ['#ffffff', '#f8f9fa', '#e9ecef', '#dee2e6', '#6c757d', '#495057', '#343a40', '#212529'],
                description: 'Clean grayscale palette with excellent contrast ratios'
            }
        ],
        typography: {
